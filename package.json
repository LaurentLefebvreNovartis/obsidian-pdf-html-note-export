{
  "name": "obsidian-pdf-html-note-export",
  "version": "1.0.0",
  "description": "Export Obsidian notes as styled PDF or self-contained HTML5 files",
  "main": "main.js",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production"
  },
  "keywords": ["obsidian", "plugin", "pdf", "html", "export"],
  "author": "Laurent Lefebvre",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^20.0.0",
    "builtin-modules": "^3.3.0",
    "esbuild": "^0.21.0",
    "obsidian": "latest",
    "tslib": "2.6.2",
    "typescript": "5.4.5"
  },
  "dependencies": {
    "jspdf": "^2.5.1",
    "html2canvas": "^1.4.1"
  }
}
